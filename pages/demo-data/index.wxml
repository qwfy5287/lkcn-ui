<view class="demo-page">
  <view class="demo-block">
    <text class="demo-block__title">Badge 徽标</text>
    <view class="demo-block__content" style="gap:48rpx;">
      <lkcn-badge content="11">
        <view style="width:80rpx;height:80rpx;background:#f5f5f5;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;">优惠券</view>
      </lkcn-badge>
      <lkcn-badge content="108" max="{{99}}">
        <view style="width:80rpx;height:80rpx;background:#f5f5f5;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;">消息</view>
      </lkcn-badge>
      <lkcn-badge dot>
        <view style="width:80rpx;height:80rpx;background:#f5f5f5;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;">新品</view>
      </lkcn-badge>
    </view>
  </view>

  <view class="demo-block">
    <text class="demo-block__title">Avatar 头像</text>
    <view class="demo-block__content" style="gap:24rpx;align-items:flex-end;">
      <lkcn-avatar src="https://placehold.co/112/1A6EFF/fff?text=Yi" size="large" />
      <lkcn-avatar src="https://placehold.co/80/C8A26E/fff?text=VIP" size="medium" level="Lv3" />
      <lkcn-avatar size="small" text="易" />
      <lkcn-avatar size="medium" shape="square" />
    </view>
  </view>

  <view class="demo-block">
    <text class="demo-block__title">LevelCard 等级卡片 — Gold</text>
    <view style="padding:0 28rpx;">
      <lkcn-level-card
        theme="gold"
        level="{{3}}"
        level-name="小金鹿"
        points="1348"
        expiry="2026-05-25到期"
        show-progress
        progress-percent="{{72}}"
        hint="加油～还差53个小蓝豆可升级，去冲刺"
      />
    </view>
  </view>

  <view class="demo-block">
    <text class="demo-block__title">LevelCard — Blue</text>
    <view style="padding:0 28rpx;">
      <lkcn-level-card
        theme="blue"
        level="{{1}}"
        level-name="小蓝豆"
        points="280"
        show-progress
        progress-percent="{{28}}"
        hint="再消费3杯即可升级"
      />
    </view>
  </view>

  <view class="demo-block">
    <text class="demo-block__title">Swiper 轮播图</text>
    <lkcn-swiper
      items="{{swiperItems}}"
      height="320rpx"
      bind:itemtap="onSwiperTap"
    />
  </view>
</view>
