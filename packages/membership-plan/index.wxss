/* lkcn-membership-plan */

.lkcn-membership-plan {
  padding: 0 var(--lkcn-page-padding, 28rpx);
}

/* ========== Plan tabs ========== */

.lkcn-membership-plan__tabs {
  display: flex;
  gap: 0;
  border-radius: var(--lkcn-radius-sm, 16rpx);
  overflow: hidden;
  border: 2rpx solid var(--lkcn-border-light, #F0F0F0);
}

.lkcn-membership-plan__tab {
  position: relative;
  flex: 1;
  padding: 28rpx 20rpx;
  background-color: var(--lkcn-bg-page, #F5F5F5);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all var(--lkcn-duration-fast, 150ms);
  cursor: pointer;
  overflow: hidden;
}

.lkcn-membership-plan__tab--active {
  background-color: var(--lkcn-bg-card, #FFFFFF);
  border: 2rpx solid var(--lkcn-blue, #1A6EFF);
  border-radius: var(--lkcn-radius-sm, 16rpx);
  margin: -2rpx;
  z-index: 1;
}

/* ========== Tab badge (e.g. "爆款天天9.9起") ========== */

.lkcn-membership-plan__tab-badge {
  position: absolute;
  top: 0;
  right: 0;
  padding: 4rpx 12rpx;
  font-size: 16rpx;
  font-weight: var(--lkcn-weight-medium, 500);
  color: var(--lkcn-text-inverse, #FFFFFF);
  background-color: var(--lkcn-orange, #FF6B35);
  border-radius: 0 0 0 var(--lkcn-radius-sm, 16rpx);
  line-height: 1.4;
  white-space: nowrap;
}

/* ========== Tab content ========== */

.lkcn-membership-plan__tab-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.lkcn-membership-plan__tab-name {
  font-size: var(--lkcn-font-sm, 24rpx);
  font-weight: var(--lkcn-weight-medium, 500);
  color: var(--lkcn-text-primary, #222222);
}

.lkcn-membership-plan__tab-price {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.lkcn-membership-plan__tab-symbol {
  font-size: var(--lkcn-font-sm, 24rpx);
  font-weight: var(--lkcn-weight-bold, 700);
  color: var(--lkcn-text-primary, #222222);
}

.lkcn-membership-plan__tab-value {
  font-size: 44rpx;
  font-weight: var(--lkcn-weight-bold, 700);
  color: var(--lkcn-text-primary, #222222);
  font-variant-numeric: tabular-nums;
  line-height: 1;
}

.lkcn-membership-plan__tab--active .lkcn-membership-plan__tab-symbol,
.lkcn-membership-plan__tab--active .lkcn-membership-plan__tab-value {
  color: var(--lkcn-blue, #1A6EFF);
}

.lkcn-membership-plan__tab-original {
  font-size: var(--lkcn-font-sm, 24rpx);
  color: var(--lkcn-text-tertiary, #999999);
  text-decoration: line-through;
  margin-left: 8rpx;
}

.lkcn-membership-plan__tab-desc {
  font-size: var(--lkcn-font-xs, 20rpx);
  color: var(--lkcn-text-tertiary, #999999);
  text-align: center;
}

/* ========== CTA button ========== */

.lkcn-membership-plan__cta {
  margin-top: var(--lkcn-spacing-lg, 32rpx);
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--lkcn-blue, #1A6EFF);
  border-radius: var(--lkcn-radius-full, 999rpx);
  transition: opacity var(--lkcn-duration-fast, 150ms);
}

.lkcn-membership-plan__cta:active {
  opacity: 0.8;
}

.lkcn-membership-plan__cta-text {
  font-size: var(--lkcn-font-lg, 30rpx);
  font-weight: var(--lkcn-weight-semibold, 600);
  color: var(--lkcn-text-inverse, #FFFFFF);
}

/* ========== Agreement ========== */

.lkcn-membership-plan__agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: var(--lkcn-spacing-md, 24rpx);
  padding-bottom: var(--lkcn-spacing-lg, 32rpx);
}

.lkcn-membership-plan__checkbox {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid var(--lkcn-border-default, #E5E5E5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: var(--lkcn-text-inverse, #FFFFFF);
  flex-shrink: 0;
}

.lkcn-membership-plan__checkbox--checked {
  background-color: var(--lkcn-blue, #1A6EFF);
  border-color: var(--lkcn-blue, #1A6EFF);
}

.lkcn-membership-plan__agreement-text {
  font-size: var(--lkcn-font-xs, 20rpx);
  color: var(--lkcn-text-tertiary, #999999);
}

.lkcn-membership-plan__agreement-link {
  font-size: var(--lkcn-font-xs, 20rpx);
  color: var(--lkcn-blue, #1A6EFF);
}
