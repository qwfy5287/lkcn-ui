/* lkcn-search-bar */

.lkcn-search-bar {
  display: flex;
  align-items: center;
  gap: var(--lkcn-spacing-md, 24rpx);
  padding: var(--lkcn-spacing-sm, 16rpx) var(--lkcn-page-padding, 28rpx);
  background-color: var(--lkcn-bg-card, #FFFFFF);
}

/* ========== Input wrapper ========== */

.lkcn-search-bar__input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--lkcn-spacing-sm, 16rpx);
  height: 68rpx;
  padding: 0 var(--lkcn-spacing-md, 24rpx);
  background-color: var(--lkcn-bg-page, #F5F5F5);
  border-radius: var(--lkcn-radius-full, 999rpx);
  transition: background-color var(--lkcn-duration-fast, 150ms);
}

.lkcn-search-bar--focus .lkcn-search-bar__input-wrap {
  background-color: var(--lkcn-bg-page, #F5F5F5);
  box-shadow: 0 0 0 2rpx var(--lkcn-blue, #1A6EFF);
}

/* ========== Icon ========== */

.lkcn-search-bar__icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

/* ========== Input ========== */

.lkcn-search-bar__input {
  flex: 1;
  height: 100%;
  font-size: var(--lkcn-font-md, 28rpx);
  color: var(--lkcn-text-primary, #222222);
  background: transparent;
}

.lkcn-search-bar__placeholder {
  font-size: var(--lkcn-font-md, 28rpx);
  color: var(--lkcn-text-placeholder, #CCCCCC);
}

/* ========== Clear button ========== */

.lkcn-search-bar__clear {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--lkcn-text-tertiary, #999999);
  background-color: var(--lkcn-border-default, #E5E5E5);
  border-radius: 50%;
  flex-shrink: 0;
  line-height: 1;
}

/* ========== Action button ========== */

.lkcn-search-bar__action {
  flex-shrink: 0;
  font-size: var(--lkcn-font-md, 28rpx);
  color: var(--lkcn-blue, #1A6EFF);
  font-weight: var(--lkcn-weight-medium, 500);
  white-space: nowrap;
}
