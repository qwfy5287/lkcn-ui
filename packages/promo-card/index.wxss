/* lkcn-promo-card */

.lkcn-promo-card {
  display: flex;
  align-items: center;
  border-radius: var(--lkcn-radius-md, 24rpx);
  overflow: hidden;
  background-size: cover;
  background-position: center;
  min-height: 180rpx;
}

/* ========== Layout variants ========== */

/* Horizontal: text left, image right (default) */
.lkcn-promo-card--horizontal {
  flex-direction: row;
  padding: 24rpx 0 24rpx 28rpx;
}

/* Vertical: image top, text bottom */
.lkcn-promo-card--vertical {
  flex-direction: column;
  padding: 0;
}

.lkcn-promo-card--vertical .lkcn-promo-card__image {
  width: 100%;
  height: 280rpx;
}

.lkcn-promo-card--vertical .lkcn-promo-card__content {
  padding: 20rpx 24rpx;
}

/* Full-width banner */
.lkcn-promo-card--banner {
  flex-direction: row;
  padding: 32rpx;
  min-height: 200rpx;
}

/* ========== Content ========== */

.lkcn-promo-card__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.lkcn-promo-card__title {
  font-size: var(--lkcn-font-lg, 30rpx);
  font-weight: var(--lkcn-weight-semibold, 600);
  color: var(--lkcn-text-primary, #222222);
  line-height: var(--lkcn-line-tight, 1.2);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.lkcn-promo-card__subtitle {
  font-size: var(--lkcn-font-sm, 24rpx);
  color: var(--lkcn-text-secondary, #666666);
  line-height: var(--lkcn-line-normal, 1.5);
}

/* ========== Action ========== */

.lkcn-promo-card__action {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 8rpx;
}

.lkcn-promo-card__action-text {
  font-size: var(--lkcn-font-sm, 24rpx);
  font-weight: var(--lkcn-weight-medium, 500);
  color: var(--lkcn-blue, #1A6EFF);
}

.lkcn-promo-card__action-arrow {
  font-size: 24rpx;
  color: var(--lkcn-blue, #1A6EFF);
}

/* ========== Image ========== */

.lkcn-promo-card__image {
  width: 200rpx;
  height: 160rpx;
  flex-shrink: 0;
}
