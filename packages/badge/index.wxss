/* lkcn-badge */

.lkcn-badge {
  position: relative;
  display: inline-block;
}

/* ========== Dot ========== */

.lkcn-badge__dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: var(--lkcn-orange, #FF6B35);
  border-radius: 50%;
  border: 2rpx solid var(--lkcn-bg-card, #FFFFFF);
}

/* ========== Number / Text content ========== */

.lkcn-badge__content {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: var(--lkcn-weight-medium, 500);
  color: var(--lkcn-text-inverse, #FFFFFF);
  background-color: var(--lkcn-orange, #FF6B35);
  border-radius: var(--lkcn-radius-full, 999rpx);
  border: 2rpx solid var(--lkcn-bg-card, #FFFFFF);
  line-height: 1;
  white-space: nowrap;
}

.lkcn-badge__content--large {
  padding: 0 10rpx;
  font-size: 18rpx;
}
