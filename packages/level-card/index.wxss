/* lkcn-level-card */

.lkcn-level-card {
  padding: var(--lkcn-spacing-xl, 48rpx) var(--lkcn-card-padding, 24rpx) var(--lkcn-spacing-lg, 32rpx);
  border-radius: var(--lkcn-radius-md, 24rpx);
}

/* ========== Theme variants ========== */

.lkcn-level-card--gold {
  background: linear-gradient(135deg, #F5ECD7 0%, #E8D5AA 100%);
}

.lkcn-level-card--gold .lkcn-level-card__level-tag {
  background-color: var(--lkcn-gold, #C8A26E);
}

.lkcn-level-card--blue {
  background: linear-gradient(135deg, #E8F0FE 0%, #D0E2FD 100%);
}

.lkcn-level-card--blue .lkcn-level-card__level-tag {
  background-color: var(--lkcn-blue, #1A6EFF);
}

.lkcn-level-card--brown {
  background: linear-gradient(135deg, #F0E4D6 0%, #D9C4AA 100%);
}

.lkcn-level-card--brown .lkcn-level-card__level-tag {
  background-color: #8B6E50;
}

/* ========== Header ========== */

.lkcn-level-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lkcn-level-card__level {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.lkcn-level-card__level-tag {
  padding: 4rpx 16rpx;
  font-size: var(--lkcn-font-xs, 20rpx);
  font-weight: var(--lkcn-weight-semibold, 600);
  color: var(--lkcn-text-inverse, #FFFFFF);
  border-radius: var(--lkcn-radius-full, 999rpx);
  line-height: 1.5;
}

.lkcn-level-card__level-name {
  font-size: var(--lkcn-font-lg, 30rpx);
  font-weight: var(--lkcn-weight-semibold, 600);
  color: var(--lkcn-text-primary, #222222);
}

.lkcn-level-card__expiry {
  font-size: var(--lkcn-font-xs, 20rpx);
  color: var(--lkcn-text-inverse, #FFFFFF);
  background-color: rgba(0, 0, 0, 0.25);
  padding: 4rpx 16rpx;
  border-radius: var(--lkcn-radius-full, 999rpx);
  line-height: 1.5;
}

/* ========== Points ========== */

.lkcn-level-card__points {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: var(--lkcn-spacing-lg, 32rpx);
}

.lkcn-level-card__points-value {
  font-size: 64rpx;
  font-weight: var(--lkcn-weight-bold, 700);
  color: var(--lkcn-text-primary, #222222);
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.lkcn-level-card__points-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ========== Progress ========== */

.lkcn-level-card__progress-wrap {
  margin-top: var(--lkcn-spacing-md, 24rpx);
}

.lkcn-level-card__progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: rgba(0, 0, 0, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.lkcn-level-card__progress-fill {
  height: 100%;
  background-color: var(--lkcn-gold, #C8A26E);
  border-radius: 4rpx;
  transition: width var(--lkcn-duration-slow, 450ms) var(--lkcn-ease-default);
}

.lkcn-level-card--blue .lkcn-level-card__progress-fill {
  background-color: var(--lkcn-blue, #1A6EFF);
}

/* ========== Hint ========== */

.lkcn-level-card__hint {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.lkcn-level-card__hint-text {
  font-size: var(--lkcn-font-sm, 24rpx);
  color: var(--lkcn-text-secondary, #666666);
}

.lkcn-level-card__hint-arrow {
  font-size: 24rpx;
  color: var(--lkcn-orange, #FF6B35);
  margin-left: 4rpx;
}
