/* lkcn-tabbar */

.lkcn-tabbar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  height: 100rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background-color: var(--lkcn-bg-card, #FFFFFF);
}

/* ========== Fixed position ========== */

.lkcn-tabbar--fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--lkcn-z-fixed, 200);
}

.lkcn-tabbar__placeholder {
  height: 100rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== Border ========== */

.lkcn-tabbar--border {
  border-top: 1rpx solid var(--lkcn-border-light, #F0F0F0);
}

/* ========== Item ========== */

.lkcn-tabbar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 100%;
  cursor: pointer;
}

/* ========== Icon ========== */

.lkcn-tabbar__icon-wrap {
  position: relative;
}

.lkcn-tabbar__icon {
  width: 44rpx;
  height: 44rpx;
}

/* ========== Badge ========== */

.lkcn-tabbar__badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: var(--lkcn-weight-medium, 500);
  color: var(--lkcn-text-inverse, #FFFFFF);
  background-color: var(--lkcn-orange, #FF6B35);
  border-radius: var(--lkcn-radius-full, 999rpx);
  line-height: 1;
}

.lkcn-tabbar__dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 14rpx;
  height: 14rpx;
  background-color: var(--lkcn-orange, #FF6B35);
  border-radius: 50%;
}

/* ========== Label ========== */

.lkcn-tabbar__label {
  font-size: var(--lkcn-font-xs, 20rpx);
  font-weight: var(--lkcn-weight-regular, 400);
  color: var(--lkcn-text-tertiary, #999999);
  line-height: 1;
}

.lkcn-tabbar__item--active .lkcn-tabbar__label {
  color: var(--lkcn-blue, #1A6EFF);
  font-weight: var(--lkcn-weight-medium, 500);
}
