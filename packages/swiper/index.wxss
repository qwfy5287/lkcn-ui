/* lkcn-swiper */

.lkcn-swiper {
  position: relative;
  width: 100%;
  overflow: hidden;
}

/* ========== Track ========== */

.lkcn-swiper__track {
  width: 100%;
  height: 360rpx; /* default, overridden by height prop */
}

/* ========== Item ========== */

.lkcn-swiper__item {
  overflow: hidden;
}

.lkcn-swiper__content {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* With page padding and rounded corners */
.lkcn-swiper--padded .lkcn-swiper__content {
  margin: 0 var(--lkcn-page-padding, 28rpx);
  border-radius: var(--lkcn-radius-md, 24rpx);
  width: calc(100% - 2 * var(--lkcn-page-padding, 28rpx));
}

/* ========== Image ========== */

.lkcn-swiper__image {
  width: 100%;
  height: 100%;
}

/* ========== Overlay text ========== */

.lkcn-swiper__overlay {
  position: absolute;
  left: 0;
  bottom: 0;
  right: 0;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lkcn-swiper__title {
  font-size: var(--lkcn-font-xl, 34rpx);
  font-weight: var(--lkcn-weight-semibold, 600);
  color: var(--lkcn-text-inverse, #FFFFFF);
  line-height: var(--lkcn-line-tight, 1.2);
}

.lkcn-swiper__subtitle {
  font-size: var(--lkcn-font-sm, 24rpx);
  color: rgba(255, 255, 255, 0.8);
  line-height: var(--lkcn-line-normal, 1.5);
}

/* ========== Dots indicator ========== */

.lkcn-swiper__dots {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.lkcn-swiper__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.4);
  transition: all var(--lkcn-duration-normal, 300ms) var(--lkcn-ease-default);
}

.lkcn-swiper__dot--active {
  width: 32rpx;
  border-radius: 6rpx;
  background-color: var(--lkcn-text-inverse, #FFFFFF);
}
